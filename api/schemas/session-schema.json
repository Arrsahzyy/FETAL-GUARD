{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "FETAL-GUARD Monitoring Session",
    "description": "Complete schema for a fetal monitoring session",
    "type": "object",
    "required": [
        "session_id",
        "patient_id",
        "device_serial",
        "device_model",
        "device_firmware_version",
        "start_time",
        "time_zone",
        "sampling_rate_hz",
        "channel_count",
        "status",
        "consent_timestamp",
        "consent_version"
    ],
    "properties": {
        "session_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the session"
        },
        "patient_id": {
            "type": "string",
            "format": "uuid",
            "description": "Reference to the patient"
        },
        "device_id": {
            "type": "string",
            "format": "uuid",
            "description": "Reference to the paired device"
        },
        "device_serial": {
            "type": "string",
            "description": "Device serial number"
        },
        "device_model": {
            "type": "string",
            "description": "Device model identifier"
        },
        "device_firmware_version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Firmware version (semver format)"
        },
        "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "Session start time in ISO-8601 format with timezone"
        },
        "end_time": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time",
            "description": "Session end time, null if still active"
        },
        "duration_seconds": {
            "type": "integer",
            "minimum": 0,
            "description": "Total session duration in seconds"
        },
        "time_zone": {
            "type": "string",
            "description": "IANA timezone identifier",
            "examples": [
                "Asia/Jakarta",
                "Asia/Makassar"
            ]
        },
        "sampling_rate_hz": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "description": "Sampling rate in Hertz"
        },
        "channel_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16,
            "description": "Number of data channels"
        },
        "status": {
            "type": "string",
            "enum": [
                "active",
                "stopped",
                "completed",
                "error"
            ],
            "description": "Current session status"
        },
        "consent_timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When user consented to data collection"
        },
        "consent_version": {
            "type": "string",
            "description": "Version of consent document accepted"
        },
        "clinic_id": {
            "type": [
                "string",
                "null"
            ],
            "format": "uuid",
            "description": "Associated clinic if shared"
        },
        "clinician_id": {
            "type": [
                "string",
                "null"
            ],
            "format": "uuid",
            "description": "Assigned clinician if any"
        },
        "raw_channels": {
            "type": "array",
            "description": "Raw data channels",
            "items": {
                "type": "object",
                "required": [
                    "channel_id",
                    "channel_type",
                    "samples"
                ],
                "properties": {
                    "channel_id": {
                        "type": "integer"
                    },
                    "channel_type": {
                        "type": "string",
                        "enum": [
                            "fhr",
                            "uterine",
                            "ecg",
                            "imu_accel",
                            "imu_gyro"
                        ]
                    },
                    "samples": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "timestamp_ms": {
                                    "type": "integer"
                                },
                                "value": {
                                    "type": "number"
                                }
                            }
                        }
                    }
                }
            }
        },
        "fhr_summary": {
            "type": "object",
            "description": "Summary of fetal heart rate data",
            "properties": {
                "baseline_bpm": {
                    "type": "number",
                    "minimum": 60,
                    "maximum": 220
                },
                "min_bpm": {
                    "type": "number"
                },
                "max_bpm": {
                    "type": "number"
                },
                "mean_bpm": {
                    "type": "number"
                },
                "median_bpm": {
                    "type": "number"
                },
                "std_dev": {
                    "type": "number"
                },
                "variability": {
                    "type": "number",
                    "description": "Heart rate variability measure"
                },
                "variability_classification": {
                    "type": "string",
                    "enum": [
                        "absent",
                        "minimal",
                        "moderate",
                        "marked"
                    ]
                }
            }
        },
        "events": {
            "type": "array",
            "description": "Detected events during session",
            "items": {
                "$ref": "#/definitions/SessionEvent"
            }
        },
        "risk_assessment": {
            "$ref": "#/definitions/RiskAssessment"
        },
        "signal_quality": {
            "$ref": "#/definitions/SignalQuality"
        },
        "imu_data": {
            "type": "object",
            "description": "Inertial measurement unit data summary",
            "properties": {
                "position_changes": {
                    "type": "integer"
                },
                "total_movement_score": {
                    "type": "number"
                },
                "predominant_position": {
                    "type": "string",
                    "enum": [
                        "supine",
                        "left_lateral",
                        "right_lateral",
                        "upright",
                        "unknown"
                    ]
                }
            }
        },
        "encryption_metadata": {
            "type": "object",
            "description": "Encryption details for at-rest storage",
            "properties": {
                "algorithm": {
                    "type": "string",
                    "enum": [
                        "AES-256-GCM",
                        "AES-256-CBC"
                    ]
                },
                "key_id": {
                    "type": "string"
                },
                "encrypted_at": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "Patient notes for this session"
        },
        "clinician_notes": {
            "type": "string",
            "description": "Notes added by clinician"
        },
        "escalation_state": {
            "type": "string",
            "enum": [
                "none",
                "pending",
                "acknowledged",
                "escalated"
            ],
            "default": "none",
            "description": "Current escalation status"
        },
        "privacy_flags": {
            "type": "object",
            "properties": {
                "location_share_allowed": {
                    "type": "boolean",
                    "default": false
                },
                "upload_allowed_wifi_only": {
                    "type": "boolean",
                    "default": true
                },
                "shared_with_clinic": {
                    "type": "boolean",
                    "default": false
                }
            }
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        },
        "deleted_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time",
            "description": "Soft delete timestamp for GDPR/retention"
        }
    },
    "definitions": {
        "SessionEvent": {
            "type": "object",
            "required": [
                "event_id",
                "type",
                "timestamp"
            ],
            "properties": {
                "event_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "acceleration",
                        "early_deceleration",
                        "late_deceleration",
                        "variable_deceleration",
                        "prolonged_deceleration",
                        "fetal_movement",
                        "maternal_signal",
                        "artifact",
                        "sensor_disconnect",
                        "position_change"
                    ]
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "duration_ms": {
                    "type": "integer",
                    "minimum": 0
                },
                "severity": {
                    "type": "string",
                    "enum": [
                        "mild",
                        "moderate",
                        "severe"
                    ]
                },
                "fhr_nadir": {
                    "type": "number",
                    "description": "Lowest FHR during deceleration"
                },
                "fhr_peak": {
                    "type": "number",
                    "description": "Highest FHR during acceleration"
                },
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "tagged_by_clinician": {
                    "type": "boolean",
                    "default": false
                },
                "clinician_notes": {
                    "type": "string"
                }
            }
        },
        "RiskAssessment": {
            "type": "object",
            "properties": {
                "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Overall risk score percentage"
                },
                "level": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ],
                    "description": "Categorical risk level"
                },
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Model confidence in prediction"
                },
                "confidence_interval": {
                    "type": "object",
                    "properties": {
                        "lower": {
                            "type": "number"
                        },
                        "upper": {
                            "type": "number"
                        }
                    }
                },
                "model_version": {
                    "type": "string",
                    "description": "Version of ML model used"
                },
                "model_type": {
                    "type": "string",
                    "enum": [
                        "rule_based",
                        "ml_cloud",
                        "ml_on_device"
                    ],
                    "description": "Type of model that generated assessment"
                },
                "explainability": {
                    "type": "string",
                    "description": "Human-readable explanation"
                },
                "contributing_factors": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "factor": {
                                "type": "string"
                            },
                            "impact": {
                                "type": "number",
                                "description": "Impact weight (-1 to 1)"
                            },
                            "description": {
                                "type": "string"
                            }
                        }
                    }
                },
                "assessed_at": {
                    "type": "string",
                    "format": "date-time"
                }
            }
        },
        "SignalQuality": {
            "type": "object",
            "properties": {
                "overall_percentage": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Overall signal quality percentage"
                },
                "classification": {
                    "type": "string",
                    "enum": [
                        "excellent",
                        "good",
                        "fair",
                        "poor"
                    ]
                },
                "components": {
                    "type": "object",
                    "properties": {
                        "snr": {
                            "type": "number",
                            "description": "Signal-to-noise ratio in dB"
                        },
                        "motion_ratio": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "description": "Ratio of time with motion artifacts"
                        },
                        "maternal_overlap_flag": {
                            "type": "boolean",
                            "description": "Whether maternal signal was detected"
                        },
                        "contact_quality": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "description": "Sensor contact quality percentage"
                        }
                    }
                },
                "segments_with_issues": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "start_ms": {
                                "type": "integer"
                            },
                            "end_ms": {
                                "type": "integer"
                            },
                            "issue_type": {
                                "type": "string",
                                "enum": [
                                    "noise",
                                    "motion",
                                    "disconnect",
                                    "maternal"
                                ]
                            }
                        }
                    }
                }
            }
        }
    }
}