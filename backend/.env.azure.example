ENVIRONMENT=production
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://<user>:<password>@<host>:5432/fetalguard_staging
AUTO_CREATE_DB=false
BACKEND_CORS_ORIGINS=["https://<your-static-web-app>.azurestaticapps.net"]
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
FG_ADMIN_EMAIL=admin@fetalguard.id
FG_ADMIN_PASSWORD=replace-with-temporary-bootstrap-password
